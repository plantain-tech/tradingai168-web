# TradingAI168 dashboard — minimal, Hostinger-safe config.
# (Trimmed to essentials — Options/Header directives can 500 on shared hosting.)

# Block direct web access to sensitive folders/files (also code-guarded).
RedirectMatch 403 ^/config/
RedirectMatch 403 ^/inc/
RedirectMatch 403 \.(sql|sample\.php)$

# Force HTTPS (Hostinger provisions the cert for the subdomain), and pass the
# Authorization header through to PHP (Apache strips it by default — needed for
# the engine's Bearer-token API).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
